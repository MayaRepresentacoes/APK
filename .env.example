# .env.example
# Google Maps API Keys
GOOGLE_MAPS_API_KEY=sua_chave_google_maps_aqui
GOOGLE_MAPS_ANDROID_API_KEY=sua_chave_android_aqui
GOOGLE_MAPS_IOS_API_KEY=sua_chave_ios_aqui
GOOGLE_MAPS_WEB_API_KEY=sua_chave_web_aqui

# Configurações do App
APP_NAME=MAYA Representações
APP_PRIMARY_COLOR=#001E2E
APP_SCHEME=maya
APP_VERSION=1.0.0

# Firebase Configuration
FIREBASE_API_KEY=sua_chave_firebase_api_key
FIREBASE_AUTH_DOMAIN=seu_projeto.firebaseapp.com
FIREBASE_PROJECT_ID=seu_projeto_id
FIREBASE_STORAGE_BUCKET=seu_projeto.appspot.com
FIREBASE_MESSAGING_SENDER_ID=1234567890
FIREBASE_APP_ID=1:1234567890:web:abc123def456